{
  "widgets": [
    {
      "type": "metric",
      "x": 0,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "metrics": [
          [ "AWS/Lambda", "Duration", "FunctionName", "compiler-runner" ],
          [ ".", "Invocations", ".", "." ]
        ],
        "period": 60,
        "stat": "Average",
        "region": "${aws_region}",
        "title": "Compiler Runner - Duration & Invocations"
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 0,
      "width": 12,
      "height": 6,
      "properties": {
        "metrics": [
          [ "AWS/SQS", "ApproximateNumberOfMessagesVisible", "QueueName", "submission-queue" ],
          [ "AWS/SQS", "ApproximateNumberOfMessagesNotVisible", "QueueName", "submission-queue" ]
        ],
        "period": 60,
        "stat": "Sum",
        "title": "Submission Queue Depth"
      }
    },
    {
      "type": "metric",
      "x": 0,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "metrics": [
          [ "AWS/RDS", "CPUUtilization", "DBInstanceIdentifier", "lms-db" ],
          [ "AWS/ElastiCache", "CPUUtilization", "CacheClusterId", "lms-cache" ]
        ],
        "period": 60,
        "stat": "Average",
        "title": "DB & Cache CPU"
      }
    },
    {
      "type": "metric",
      "x": 12,
      "y": 6,
      "width": 12,
      "height": 6,
      "properties": {
        "metrics": [
          [ "AWS/EC2", "NetworkIn", "InstanceId", "i-EXAMPLE" ],
          [ "AWS/EC2", "NetworkOut", "InstanceId", "i-EXAMPLE" ]
        ],
        "period": 60,
        "stat": "Sum",
        "title": "Network I/O (example hosts)"
      }
    }
  ]
}
