{
  "name": "lms-backend",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": "20.15.0"
  },
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "worker": "tsx src/worker.ts",
    "worker:dev": "tsx watch src/worker.ts",
    "sqs:mock": "tsx scripts/local-sqs-mock.ts",
    "lambda:api": "tsx src/lambda/api.ts",
    "lambda:worker": "tsx src/lambda/submissionWorker.ts",
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:compiler": "npm run build --prefix compiler-service",
    "start": "node dist/src/server.js",
    "lint": "eslint . --ext .ts",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify:submission-flow": "tsx scripts/verify-submission-flow.ts",
    "test:load": "tsx scripts/load-test-submissions.ts",
    "verify:production-launch": "npm run verify:submission-flow && npm run test:load",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push --skip-generate",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "bootstrap:admin": "tsx scripts/bootstrap-admin.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/client-secrets-manager": "^3.600.0",
    "@aws-sdk/client-sqs": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@prisma/client": "^5.16.0",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.16.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.2.0",
    "pino-http": "^10.3.0",
    "serverless-http": "^4.0.0",
    "uuid": "^9.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "pino-pretty": "^11.2.2",
    "prisma": "^5.16.0",
    "supertest": "^6.3.4",
    "tsx": "^4.16.2",
    "tsc-alias": "^1.8.10",
    "typescript": "5.5.4",
    "vitest": "^1.6.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
