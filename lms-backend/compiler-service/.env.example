# Compiler service
LOG_LEVEL=info
COMPILER_PORT=4000

# Local sandbox execution fallback
EXEC_BASE=/tmp/lms-exec
SANDBOX_BIN=/usr/local/bin/sandbox-run
RUNNER_UID=10001
RUNNER_GID=10001
COMPILER_MAX_CODE_BYTES=65536
COMPILER_MAX_STDIN_BYTES=65536
COMPILER_MAX_OUTPUT_BYTES=65536
COMPILER_MAX_REQUEST_BYTES=262144

# Optional Lambda runner URLs (when set, /execute invokes these)
COMPILER_RUNNER_PYTHON_URL=
COMPILER_RUNNER_JAVA_URL=
COMPILER_RUNNER_CPP_URL=
COMPILER_RUNNER_C_URL=
